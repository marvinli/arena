{
  "name": "arena",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "front-end": "npm run dev --workspace=@arena/front-end",
    "proctor-api": "npm run dev --workspace=@arena/proctor-api",
    "videographer": "npm run dev --workspace=@arena/videographer",
    "test:proctor-api": "npm test --workspace=@arena/proctor-api",
    "run-game": "npm run run-game --workspace=@arena/proctor-api",
    "codegen:front-end": "npm run codegen --workspace=@arena/front-end",
    "test:front-end": "npm test --workspace=@arena/front-end",
    "admin-api": "npm run dev --workspace=@arena/admin-api",
    "admin-fe": "npm run dev --workspace=@arena/admin-fe",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "cdk:synth": "npm run synth --workspace=@arena/deploy",
    "cdk:deploy": "npm run deploy --workspace=@arena/deploy",
    "cdk:diff": "npm run diff --workspace=@arena/deploy",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
