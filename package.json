{
  "name": "arena",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "front-end": "npm run dev --workspace=@arena/front-end",
    "poker-api": "npm run dev --workspace=@arena/poker-api",
    "proctor-api": "npm run dev --workspace=@arena/proctor-api",
    "test:poker-api": "npm test --workspace=@arena/poker-api",
    "test:proctor-api": "npm test --workspace=@arena/proctor-api",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
