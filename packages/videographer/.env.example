# Twitch RTMP ingest (or any RTMP endpoint)
RTMP_URL=rtmp://live.twitch.tv/app/YOUR_STREAM_KEY_HERE

# Or record to local file instead of streaming
# OUTPUT_FILE=recording.mp4

# Front-end URL to capture
# FRONTEND_URL=http://localhost:5173/

# Capture settings
# CAPTURE_WIDTH=1920
# CAPTURE_HEIGHT=1080
# CAPTURE_FPS=30

# Custom Chrome/Chromium path (uses puppeteer default if omitted)
# CHROME_PATH=/usr/bin/google-chrome
