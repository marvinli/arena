{
  "name": "@arena/admin-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "build:lambda": "esbuild src/lambda.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/lambda.mjs --external:@aws-sdk/*",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-ecs": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "graphql": "^16.9.0",
    "graphql-yoga": "^5.10.6",
    "jose": "^6.0.11"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "esbuild": "^0.24.0",
    "vitest": "^3.0.5"
  }
}
