ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

OPENAI_API_KEY=sk-proj-your-openai-key-here

GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key-here

XAI_API_KEY=your-xai-key-here

DEEPSEEK_API_KEY=sk-your-deepseek-key-here

INWORLD_API_KEY=your-inworld-key-here

TTS_PROVIDER=inworld

AWS_REGION=us-east-1

# DynamoDB table prefix (must match CDK DatabaseStack)
TABLE_PREFIX=arena-

# Videographer — Twitch RTMP (or local file recording)
RTMP_URL=rtmp://live.twitch.tv/app/YOUR_STREAM_KEY_HERE
# OUTPUT_FILE=recording.mp4

# Google OAuth (Cognito IdP)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

VITE_DISABLE_TTS=true
